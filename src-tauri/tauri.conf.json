{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "saynow",
  "version": "0.1.0",
  "identifier": "com.voiceinput.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "说文",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      },
      {
        "label": "recorder",
        "url": "index.html?view=recorder",
        "title": "说文录音",
        "width": 360,
        "height": 72,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "focusable": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
