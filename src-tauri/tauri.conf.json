{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "saynow",
  "version": "0.1.2",
  "identifier": "com.voiceinput.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "说文",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
